#!/bin/sh
# KeeperFX AppImage launcher.
#
# KeeperFX needs a writable game folder with the free KeeperFX data (bundled here) and
# the original Dungeon Keeper files (which you must own - GOG/Steam/CD - and which are
# NOT bundled for copyright reasons). On a graphical first run this offers a folder
# picker to import them; it never starts the engine without data (a GUI double-click
# would otherwise silently appear to do nothing).
HERE="$(dirname "$(readlink -f "$0")")"
export LD_LIBRARY_PATH="$HERE/usr/lib:$LD_LIBRARY_PATH"

GAMEDIR="${KEEPERFX_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/keeperfx}"
mkdir -p "$GAMEDIR"
# Deploy the bundled free FX data. no-clobber keeps the user's DK files, saves and config.
cp -rn "$HERE/usr/share/keeperfx/." "$GAMEDIR/" 2>/dev/null || true
cd "$GAMEDIR" || exit 1

has_data() { [ -f "$GAMEDIR/sound/atlas/bullfrog.sbk" ] || [ -f "$GAMEDIR/data/cube.dat" ]; }
have()     { command -v "$1" >/dev/null 2>&1; }
gui()      { [ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ]; }
# Host GUI tools must run WITHOUT the AppImage's bundled libs, or the host zenity/kdialog
# crashes against our older bundled libssl etc. (see fix 09).
sysrun()   { env -u LD_LIBRARY_PATH "$@"; }

pick_dir() {
  if   have zenity;  then sysrun zenity  --file-selection --directory \
         --title="Select your original Dungeon Keeper folder (GOG install dir / CD 'keeper')"
  elif have kdialog; then sysrun kdialog --title "KeeperFX" --getexistingdirectory "$HOME"
  else return 1; fi
}
notify() {
  echo "$1" >&2
  gui || return 0
  if   have zenity;  then sysrun zenity  --error --title="KeeperFX" --text="$1" 2>/dev/null
  elif have kdialog; then sysrun kdialog --title "KeeperFX" --error "$1"          2>/dev/null
  fi
}

# Import the original DK data from any reasonable choice (root / inner `data` / a parent):
# locate cube.dat, take its grandparent as the DK root, copy data/ldata/sound/levels
# lowercased, no-clobber. Returns success only if data/cube.dat ends up in the game folder.
import_dk() {
  cube=$(find "$1" -maxdepth 4 -iname 'cube.dat' 2>/dev/null | head -1)
  [ -n "$cube" ] || return 1
  root=$(CDPATH= cd -- "$(dirname "$(dirname "$cube")")" && pwd) || return 1
  for sub in data ldata sound levels; do
    [ -d "$root/$sub" ] || continue
    ( cd "$root/$sub" && find . -type f ) | while IFS= read -r f; do
      lc=$(printf '%s' "$f" | tr 'A-Z' 'a-z'); lc="${lc#./}"
      dest="$GAMEDIR/$sub/$lc"
      [ -e "$dest" ] || { mkdir -p "$(dirname "$dest")"; cp "$root/$sub/$f" "$dest"; }
    done
  done
  [ -f "$GAMEDIR/data/cube.dat" ]
}

if ! has_data; then
  echo "KeeperFX needs the original Dungeon Keeper files (you must own the game)." >&2
  echo "Copy your DK 'data','sound','ldata','levels' into: $GAMEDIR  (GOG dir / CD 'keeper')." >&2

  if gui && { have zenity || have kdialog; }; then
    src=$(pick_dir)
    [ -n "$src" ] && [ -d "$src" ] && import_dk "$src"
  fi

  if ! has_data; then
    notify "No Dungeon Keeper data found.

Start KeeperFX again and select your GOG install folder (or the CD 'keeper' folder)."
    exit 1
  fi
fi

exec "$HERE/usr/bin/keeperfx" "$@"
